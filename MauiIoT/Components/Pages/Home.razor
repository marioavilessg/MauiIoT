@page "/"

@inject IJSRuntime JS

<div class="flex flex-col h-full bg-[#0d1117] overflow-hidden" style="font-family:'Inter',system-ui,sans-serif">

    <!-- HEADER -->
    <header class="flex-shrink-0 flex items-center justify-between px-5 py-3"
            style="background:#111827;border-bottom:1px solid rgba(255,255,255,0.06);box-shadow:0 4px 24px rgba(0,0,0,0.4)">

        <div class="flex items-center gap-3">
            <div style="width:36px;height:36px;border-radius:10px;
                        background:linear-gradient(135deg,#06b6d4,#1d4ed8);
                        display:flex;align-items:center;justify-content:center;">
                ⚡
            </div>
            <div>
                <h1 style="margin:0;font-size:14px;font-weight:700;color:#f9fafb;">IoT Assistant</h1>
                <p style="margin:2px 0 0;font-size:10px;color:#6b7280">Wokwi Board Control</p>
            </div>
        </div>

        <div class="flex items-center gap-3">
            <div style="display:flex;align-items:center;gap:6px">
                <span style="width:8px;height:8px;border-radius:50%;
                             background:@(isConnected ? "#34d399" : "#f87171")"></span>
                <span style="font-size:11px;color:#9ca3af">
                    @(isConnected ? "Conectado" : "Sin conexión")
                </span>
            </div>
        </div>
    </header>

    <!-- CHAT -->
    <div id="chat-container"
         class="flex-1 overflow-y-auto px-4 py-5"
         style="display:flex;flex-direction:column;gap:14px">

        @foreach (var msg in messages)
        {
            if (msg.Role == "user")
            {
                <div style="display:flex;justify-content:flex-end;">
                    <div style="max-width:75%">
                        <div style="background:linear-gradient(135deg,#0891b2,#1d4ed8);color:white;
                                    border-radius:18px 18px 4px 18px;padding:10px 16px;">
                            @msg.Content
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div style="display:flex;justify-content:flex-start;">
                    <div style="max-width:75%">
                        <div style="background:#1a2132;border-radius:18px 18px 18px 4px;
                                    padding:10px 16px;color:#f3f4f6;">
                            @msg.Content
                        </div>
                    </div>
                </div>
            }
        }

        @if (isTyping)
        {
            <div>🤖 escribiendo...</div>
        }

        <div id="chat-bottom"></div>
    </div>

    <!-- INPUT -->
    <div class="flex-shrink-0 px-4 pb-4 pt-3"
         style="background:#111827;border-top:1px solid rgba(255,255,255,.06)">

        <textarea
            id="chat-input"
            @oninput="HandleInput"
            rows="1"
            placeholder="Escribe un comando…"
            style="width:100%;background:#1a2132;color:#f3f4f6;
                   border-radius:14px;padding:12px 16px;">
        </textarea>

        <button @onclick="EnviarComando"
                disabled="@(isTyping || string.IsNullOrWhiteSpace(comando))"
                style="margin-top:10px;width:100%;padding:12px;border-radius:14px;
                       background:linear-gradient(135deg,#06b6d4,#1d4ed8);
                       color:white;">
            Enviar
        </button>
    </div>

</div>

@code {

    record ChatMessage(string Role, string Content, DateTime Time);

    class ChatResponse
    {
        public string? Action { get; set; }
        public string? Result { get; set; }
        public string Message { get; set; } = "";
        public bool Success { get; set; }
    }

    string comando = "";
    bool isTyping = false;
    bool isConnected = true;

    List<ChatMessage> messages = new();

    DotNetObjectReference<Home>? _dotNetRef;

    protected override void OnInitialized()
    {
        messages.Add(new ChatMessage(
            "assistant",
            "¡Hola! 👋 Escribe un comando para controlar las luces.",
            DateTime.Now));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("setupChatInput", _dotNetRef, "chat-input");
            await ScrollToBottom();
        }
    }

    [JSInvokable]
    public async Task OnEnterPressed(string text)
    {
        await EnviarComandoConTexto(text);
    }

    void HandleInput(ChangeEventArgs e)
    {
        comando = e.Value?.ToString() ?? "";
    }

    async Task EnviarComando()
    {
        if (string.IsNullOrWhiteSpace(comando) || isTyping) return;

        var text = comando.Trim();
        comando = "";

        StateHasChanged();

        try { await JS.InvokeVoidAsync("resetInput", "chat-input"); } catch { }

        await EnviarComandoConTexto(text);
    }

    async Task EnviarComandoConTexto(string userMsg)
    {
        if (string.IsNullOrWhiteSpace(userMsg) || isTyping) return;

        isTyping = true;
        StateHasChanged();

        messages.Add(new ChatMessage("user", userMsg, DateTime.Now));
        
        StateHasChanged();
        await ScrollToBottom();

        try
        {
            var http = new HttpClient();

            var body = new
            {
                message = userMsg
            };

            var response = await http.PostAsJsonAsync(
                "http://localhost:5000/api/chat",
                body
            );

            var result = await response.Content.ReadFromJsonAsync<ChatResponse>();

            isConnected = true;

            messages.Add(new ChatMessage(
                "assistant",
                result?.Message ?? "Sin respuesta",
                DateTime.Now));
        }
        catch (Exception ex)
        {
            isConnected = false;

            messages.Add(new ChatMessage(
                "assistant",
                $"Error: {ex.Message}",
                DateTime.Now));
        }

        isTyping = false;
        StateHasChanged();
        await ScrollToBottom();
    }

    async Task ScrollToBottom()
    {
        try { await JS.InvokeVoidAsync("scrollToBottom", "chat-container"); }
        catch { }
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
}